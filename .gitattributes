
# Treat these as binary (no text eol conversions)
*.db binary
*.sqlite binary

# Use LFS for big artifacts (optional; uncomment if you expect >100MB)
# *.db filter=lfs diff=lfs merge=lfs -text
# *.sqlite filter=lfs diff=lfs merge=lfs -text

# Ensure JSONL/CSV are diffed as text
*.jsonl text eol=lf
*.json text eol=lf
*.csv text eol=lf
*.sql text eol=lf
*.py text eol=lf
*.md text eol=lf
