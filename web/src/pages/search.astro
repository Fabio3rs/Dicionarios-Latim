---
import Layout from "../components/Layout.astro";
import FiltersPanel from "../components/FiltersPanel.astro";
import "../styles/base.css";

const base = import.meta.env.BASE_URL || "/Dicionarios-Latim";
const baseWithSlash = base.endsWith("/") ? base : `${base}/`;
const dataBase = `${baseWithSlash}data`;
---

<Layout
  title="Busca | Dicionários"
  description="Busca estática com Pagefind nos dicionários."
  breadcrumbs={[{ label: "Início", href: `${baseWithSlash}` }, { label: "Busca" }]}
>
  <div class="layout-grid">
    <FiltersPanel loading={true} />

    <section aria-label="Resultados" class="panel results-panel">
      <header class="results-header">
        <div>
          <p class="muted results-header-label">Busca estática (Pagefind)</p>
          <h1 class="results-header-title">Resultados</h1>
        </div>
        <div class="results-controls">
          <label class="sr-only" for="search-box">Buscar</label>
          <input id="search-box" class="input search-input" type="search" placeholder="Buscar verbete…" list="suggestions" autocomplete="off" />
          <datalist id="suggestions"></datalist>

          <label for="page-size" class="muted page-size-label">Itens por página:</label>
          <select id="page-size" class="input page-size-select">
            <option value="10">10</option>
            <option value="25" selected>25</option>
            <option value="50">50</option>
            <option value="100">100</option>
          </select>
        </div>
      </header>

      <div id="results" class="results-list" aria-live="polite" aria-atomic="false">
        <p class="muted">Carregando índice…</p>
      </div>
    </section>
  </div>

  <script type="module" define:vars={{ baseWithSlash, dataBase }}>
    const assetBase = baseWithSlash;
    const dataBaseUrl = dataBase;
    const resultsEl = document.getElementById("results");
    const searchBox = document.getElementById("search-box");
    const pageSizeSel = document.getElementById("page-size");
    const filtersRoot = document.querySelector("aside[aria-label='Filtros']");
    const datalist = document.getElementById("suggestions");

    let checkboxNodes = [];
    let letterNodes = [];
    let morfNodes = [];
    let topLemmas = [];

    const state = {
      term: "",
      pageSize: 25,
      page: 1,
      filters: {}, // volume_id, morfologia, morph_render, first_letter, conf, needs_review
    };

    function qsParamsToState() {
      const params = new URLSearchParams(window.location.search);
      state.term = params.get("term") || "";
      state.pageSize = parseInt(params.get("pageSize") || "25", 10) || 25;
      ["volume_id", "morfologia", "morph_render", "first_letter", "conf", "needs_review"].forEach((key) => {
        const vals = params.getAll(key);
        if (vals.length) state.filters[key] = vals;
      });
    }

    function syncUrl() {
      const params = new URLSearchParams();
      if (state.term.trim()) params.set("term", state.term.trim());
      if (state.pageSize && state.pageSize !== 25) params.set("pageSize", String(state.pageSize));
      Object.entries(state.filters).forEach(([k, vals]) => {
        vals.forEach((v) => params.append(k, v));
      });
      const newUrl = `${window.location.pathname}${params.toString() ? `?${params.toString()}` : ""}`;
      window.history.replaceState({}, "", newUrl);
    }

    qsParamsToState();
    searchBox.value = state.term;
    pageSizeSel.value = String(state.pageSize);

    let pagefindPromise = null;

    const basePath = assetBase.endsWith("/") ? assetBase.slice(0, -1) : assetBase;

    function ensurePagefind() {
      if (!pagefindPromise) {
        pagefindPromise = import(`${assetBase}pagefind/pagefind.js`)
          .then((mod) => mod?.default || mod?.pagefind || mod)
          .catch((err) => { pagefindPromise = null; throw err; });
      }
      return pagefindPromise;
    }

    function normalizeUrl(raw) {
      if (!raw) return "#";
      if (/^https?:\/\//i.test(raw)) return raw;
      let path = raw.trim();
      const baseNoSlash = basePath.replace(/^\//, "");
      const stripPrefixes = [basePath, `${basePath}/`, baseNoSlash, `${baseNoSlash}/`];
      for (const pref of stripPrefixes) {
        while (path.startsWith(pref)) path = path.slice(pref.length);
      }
      if (!path.startsWith("/")) path = `/${path}`;
      return `${basePath}${path}`;
    }

    async function loadFilters() {
      try {
        const volumes = await fetch(`${dataBaseUrl}/volumes.json`).then((r) => r.json());
        const volSelect = document.createElement("select");
        volSelect.className = "input";
        volSelect.id = "volume-select";
        volumes.forEach((v) => {
          const opt = document.createElement("option");
          opt.value = v.id;
          opt.textContent = v.title || v.id;
          volSelect.appendChild(opt);
        });
        if (state.filters.volume_id?.length) {
          volSelect.value = state.filters.volume_id[0];
        }

        // Morfologia
        const morfResp = await fetch(`${assetBase}data/${volSelect.value}/dict/morfologia.json`).then((r) => r.json());
        const morfSection = document.createElement("div");
        morfResp.forEach((m) => {
          const label = document.createElement("label");
          label.style.display = "flex";
          label.style.alignItems = "center";
          label.style.gap = "0.35rem";
          const cb = document.createElement("input");
          cb.type = "checkbox";
          cb.name = "morfologia";
          cb.value = m;
          if (state.filters.morfologia?.includes(m)) cb.checked = true;
          label.appendChild(cb);
          label.append(m);
          morfSection.appendChild(label);
        });

        // Confiança
        const confSelect = document.createElement("select");
        confSelect.className = "input";
        ["", "conf:high", "conf:med", "conf:low"].forEach((c) => {
          const opt = document.createElement("option");
          opt.value = c;
          opt.textContent = c ? c.replace("conf:", "conf:") : "(qualquer)";
          confSelect.appendChild(opt);
        });
        if (state.filters.conf?.length) confSelect.value = state.filters.conf[0];

        // Revisão pendente
        const revLabel = document.createElement("label");
        revLabel.style.display = "flex";
        revLabel.style.alignItems = "center";
        revLabel.style.gap = "0.35rem";
        const revCb = document.createElement("input");
        revCb.type = "checkbox";
        revCb.name = "needs_review";
        revCb.value = "1";
        if (state.filters.needs_review?.includes("1")) revCb.checked = true;
        revLabel.appendChild(revCb);
        revLabel.append("Somente pendentes de revisão");

        // Letras
        const letterCounts = await fetch(`${assetBase}data/${volSelect.value}/dict/lemmas-first-letter.json`).then((r) => r.json());
        const lettersWrap = document.createElement("div");
        lettersWrap.className = "chips";
        "ABCDEFGHIJKLMNOPQRSTUVWXYZ".split("").forEach((ch) => {
          const btn = document.createElement("button");
          btn.type = "button";
          btn.className = "chip";
          btn.dataset.letter = ch;
          if (state.filters.first_letter?.includes(ch)) btn.classList.add("active");
          btn.textContent = letterCounts[ch] ? `${ch} (${letterCounts[ch]})` : ch;
          lettersWrap.appendChild(btn);
        });

        // Página
        const volMeta = await fetch(`${assetBase}${volumes.find((v) => v.id === volSelect.value).meta_url}`).then((r) => r.json());
        // Sem páginas neste build

        filtersRoot.innerHTML = "";

        const panel = document.querySelector("aside[aria-label='Filtros']");
        panel.innerHTML = `
          <h2 style="margin-top:0;">Filtros</h2>
          <div class="filters-stack"></div>
          <button class="button secondary" id="clear-filters" style="margin-top:var(--space-3);">Limpar filtros</button>
        `;
        const stack = panel.querySelector(".filters-stack");

        const secVol = document.createElement("section");
        secVol.innerHTML = `<h3 style="margin:0 0 var(--space-2);">Volume</h3>`;
        secVol.appendChild(volSelect);
        stack.appendChild(secVol);

        const secMorf = document.createElement("section");
        secMorf.innerHTML = `<h3 style="margin:0 0 var(--space-2);">Morfologia</h3>`;
        secMorf.appendChild(morfSection);
        stack.appendChild(secMorf);

        const secConf = document.createElement("section");
        secConf.innerHTML = `<h3 style="margin:0 0 var(--space-2);">Confiança</h3>`;
        secConf.appendChild(confSelect);
        stack.appendChild(secConf);

        const secRev = document.createElement("section");
        secRev.innerHTML = `<h3 style="margin:0 0 var(--space-2);">Revisão</h3>`;
        secRev.appendChild(revLabel);
        stack.appendChild(secRev);

        const secLetra = document.createElement("section");
        secLetra.innerHTML = `<h3 style="margin:0 0 var(--space-2);">Inicial</h3>`;
        secLetra.appendChild(lettersWrap);
        stack.appendChild(secLetra);

        // páginas removidas

        // Sugestões
        topLemmas = await fetch(`${assetBase}data/${volSelect.value}/dict/lemmas-top.json`).then((r) => r.json()).then((d) => d.items || []);

        // Bind events
        volSelect.addEventListener("change", async () => {
          state.filters = { volume_id: [volSelect.value] };
          state.page = 1;
          syncUrl();
          await loadFilters(); // aguarda antes de renderizar com os novos filtros
          render();
        });

        morfNodes = Array.from(secMorf.querySelectorAll("input[type='checkbox']"));
        morfNodes.forEach((cb) =>
          cb.addEventListener("change", () => {
            const selected = morfNodes.filter((c) => c.checked).map((c) => c.value);
            if (selected.length) state.filters.morfologia = selected;
            else delete state.filters.morfologia;
            state.page = 1;
            syncUrl();
            render();
          })
        );

        letterNodes = Array.from(lettersWrap.querySelectorAll("button.chip"));
        letterNodes.forEach((btn) =>
          btn.addEventListener("click", () => {
            const isActive = btn.classList.contains("active");
            letterNodes.forEach((b) => b.classList.remove("active"));
            if (!isActive) {
              btn.classList.add("active");
              state.filters.first_letter = [btn.dataset.letter];
            } else {
              delete state.filters.first_letter;
            }
            state.page = 1;
            syncUrl();
            render();
          })
        );

        confSelect.addEventListener("change", () => {
          const val = confSelect.value;
          if (val) state.filters.conf = [val];
          else delete state.filters.conf;
          state.page = 1;
          syncUrl();
          render();
        });

        revCb.addEventListener("change", () => {
          if (revCb.checked) state.filters.needs_review = ["1"];
          else delete state.filters.needs_review;
          state.page = 1;
          syncUrl();
          render();
        });

        document.getElementById("clear-filters").addEventListener("click", async () => {
          state.filters = {};
          state.term = "";
          state.pageSize = 25;
          state.page = 1;
          searchBox.value = "";
          pageSizeSel.value = "25";
          syncUrl();
          await loadFilters();
          render();
        });
    } catch (err) {
      filtersRoot.innerHTML = '<p class="muted" style="margin:0;">Filtros indisponíveis.</p>';
      console.error(err);
    }
  }

    function updateSuggestions() {
      const term = (searchBox.value || "").toLowerCase();
      if (!term || topLemmas.length === 0) {
        datalist.innerHTML = "";
        return;
      }
      const suggestions = topLemmas
        .filter((k) => (k.label || "").toLowerCase().includes(term))
        .slice(0, 15);
      datalist.innerHTML = suggestions.map((s) => `<option value="${s.label}"></option>`).join("");
    }

    async function render() {
      const term = (state.term || "").trim();
      const filters = { ...state.filters };
      const pageSize = state.pageSize || 25;
      const noCriteria = term === "" && Object.keys(filters).length === 0;

      // Mostra estado de carregamento
      resultsEl.innerHTML = "";
      const loadingP = document.createElement("p");
      loadingP.className = "muted";
      loadingP.textContent = "Buscando…";
      resultsEl.appendChild(loadingP);

      try {
        const pf = await ensurePagefind();
        if (!pf) {
          resultsEl.textContent = "Índice Pagefind não disponível.";
          return;
        }
        const searchTerm = term === "" ? null : term;
        const res = await pf.search(searchTerm, { filters: Object.keys(filters).length ? filters : undefined });
        if (!res || !res.results) {
          resultsEl.textContent = "Índice vazio ou não carregado.";
          return;
        }

        const totalResults = res.results.length;

        const list = document.createElement("div");
        list.className = "results-list";

        if (noCriteria && totalResults === 0) {
          resultsEl.innerHTML = "";
          const p = document.createElement("p");
          p.className = "muted";
          p.textContent = "Nenhum índice carregado.";
          resultsEl.appendChild(p);
          return;
        }

        if (noCriteria) {
          // Paginação manual (não carrega todos os data() de uma vez)
          const totalPages = Math.max(1, Math.ceil(totalResults / pageSize));
          state.page = Math.min(Math.max(1, state.page), totalPages);
          const start = (state.page - 1) * pageSize;
          const end = Math.min(start + pageSize, totalResults);
          const slice = res.results.slice(start, end);
          const hits = await Promise.all(slice.map((r) => r.data()));
          hits.sort((a, b) => (a.meta?.lemmas || "").localeCompare(b.meta?.lemmas || "", "pt"));

          const info = document.createElement("div");
          info.className = "pagination";

          const summary = document.createElement("span");
          summary.textContent = `Listando ${start + 1}–${end} de ${totalResults} verbetes (ordem alfabética)`;
          info.appendChild(summary);

          const navDiv = document.createElement("div");
          navDiv.style.display = "flex";
          navDiv.style.gap = "0.5rem";
          navDiv.style.alignItems = "center";

          const prevBtn = document.createElement("button");
          prevBtn.textContent = "← Anterior";
          prevBtn.disabled = state.page === 1;
          prevBtn.setAttribute("aria-label", "Página anterior");

          const pageSpan = document.createElement("span");
          pageSpan.textContent = `Página ${state.page}/${totalPages}`;

          const nextBtn = document.createElement("button");
          nextBtn.textContent = "Próxima →";
          nextBtn.disabled = state.page === totalPages;
          nextBtn.setAttribute("aria-label", "Próxima página");

          prevBtn.addEventListener("click", () => { state.page = Math.max(1, state.page - 1); render(); });
          nextBtn.addEventListener("click", () => { state.page = Math.min(totalPages, state.page + 1); render(); });

          navDiv.appendChild(prevBtn);
          navDiv.appendChild(pageSpan);
          navDiv.appendChild(nextBtn);
          info.appendChild(navDiv);
          list.appendChild(info);

          hits.forEach((hit) => list.appendChild(renderCard(hit)));

          resultsEl.innerHTML = "";
          resultsEl.appendChild(list);
          return;
        }

        // Busca com termo ou filtros
        let hits = await Promise.all(res.results.map((r) => r.data()));
        const total = hits.length;
        let truncated = false;
        if (term === "" && total > pageSize) {
          hits = hits.slice(0, pageSize);
          truncated = true;
        }
        if (!hits.length) {
          resultsEl.innerHTML = "";
          const p = document.createElement("p");
          p.className = "muted";
          p.textContent = "Nenhum resultado.";
          resultsEl.appendChild(p);
          return;
        }

        if (truncated) {
          const info = document.createElement("p");
          info.className = "muted";
          info.textContent = `Mostrando ${hits.length} de ${total}. Aplique filtros ou aumente 'Itens'.`;
          list.appendChild(info);
        }

        hits.forEach((hit) => list.appendChild(renderCard(hit)));

        resultsEl.innerHTML = "";
        resultsEl.appendChild(list);
      } catch (err) {
        console.error(err);
        resultsEl.textContent = "Erro ao buscar. Verifique o console.";
      }
    }

    function renderCard(hit) {
      const card = document.createElement("article");
      card.className = "result-card";
      const lemmas = hit.meta?.lemmas || "Verbete";
      const h3 = document.createElement("h3");
      const a = document.createElement("a");
      const target = normalizeUrl(hit.url || "#");
      a.href = target;
      a.textContent = lemmas;
      h3.appendChild(a);
      card.appendChild(h3);

      const meta = document.createElement("div");
      meta.className = "result-meta";
      if (hit.meta?.morfologia) {
        const b = document.createElement("span");
        b.className = "badge badge--clickable";
        b.textContent = hit.meta.morfologia;
        b.title = "filtrar por esta morfologia";
        b.setAttribute("role", "button");
        b.setAttribute("tabindex", "0");
        const filterByMorf = () => {
          state.filters.morfologia = [hit.meta.morfologia];
          state.page = 1;
          syncUrl();
          render();
        };
        b.addEventListener("click", filterByMorf);
        b.addEventListener("keydown", (e) => { if (e.key === "Enter" || e.key === " ") { e.preventDefault(); filterByMorf(); } });
        meta.appendChild(b);
      }
      if (hit.meta?.conf) {
        const b = document.createElement("span");
        b.className = "badge";
        b.textContent = hit.meta.conf;
        b.title = "nível de confiança";
        meta.appendChild(b);
      }
      if (hit.meta?.gloss_lang) {
        const b = document.createElement("span");
        b.className = "badge";
        b.textContent = hit.meta.gloss_lang;
        b.title = "idioma da definição";
        meta.appendChild(b);
      }
      if (hit.meta?.needs_review === "1") {
        const b = document.createElement("span");
        b.className = "badge";
        b.textContent = "revisar";
        b.title = "marcado para revisão";
        meta.appendChild(b);
      }
      if (hit.meta?.redirect_only === "1") {
        const b = document.createElement("span");
        b.className = "badge";
        b.textContent = "↪ remissiva";
        meta.appendChild(b);
      }
      // página removida neste build
      const vol = document.createElement("span");
      vol.className = "muted";
      vol.textContent = hit.meta?.volume_id || "";
      meta.appendChild(vol);
      card.appendChild(meta);

      const snip = document.createElement("p");
      snip.className = "result-excerpt muted";
      // hit.excerpt contém <mark> para highlight — é gerado pelo Pagefind (conteúdo interno confiável)
      if (hit.excerpt) {
        snip.innerHTML = hit.excerpt;
      } else {
        snip.textContent = (hit.content || "").slice(0, 180);
      }
      card.appendChild(snip);
      return card;
    }

    let debounceTimer = null;

    function handleTermInput(immediate = false) {
      state.term = searchBox.value;
      state.page = 1;
      syncUrl();
      updateSuggestions();
      clearTimeout(debounceTimer);
      if (immediate) {
        render();
      } else {
        debounceTimer = setTimeout(render, 250);
      }
    }

    searchBox.addEventListener("input", () => {
      handleTermInput(false);
    });
    searchBox.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        handleTermInput(true);
      }
    });
    pageSizeSel.addEventListener("change", () => {
      const val = parseInt(pageSizeSel.value, 10);
      state.pageSize = Number.isNaN(val) ? 25 : val;
      state.page = 1;
      syncUrl();
      render();
    });

    // inicial
    loadFilters().then(() => {
      render();
      updateSuggestions();
    });
  </script>
</Layout>
