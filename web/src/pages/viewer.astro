---
import Layout from "../components/Layout.astro";
import "../styles/base.css";

const base = import.meta.env.BASE_URL || "/Dicionarios-Latim";
const baseWithSlash = base.endsWith("/") ? base : `${base}/`;
const dataBase = `${baseWithSlash}data`;
---

<Layout
  title="Verbete | Dicionários"
  description="Visualização de verbete"
  breadcrumbs={[
    { label: "Início", href: baseWithSlash },
    { label: "Busca", href: `${baseWithSlash}search` },
    { label: "Verbete" },
  ]}
>
  <section class="panel page-narrow" id="content">
    <p class="muted">Carregando...</p>
  </section>

  <script type="module" define:vars={{ baseWithSlash, dataBase }}>
    const params = new URLSearchParams(window.location.search);
    const volParam = params.get("vol");
    const idParam = params.get("id");
    const content = document.getElementById("content");
    const dataBaseUrl = dataBase;

    /** Cria um elemento com textContent seguro (evita XSS). */
    function el(tag, text, cls) {
      const e = document.createElement(tag);
      if (cls) e.className = cls;
      if (text != null) e.textContent = text;
      return e;
    }

    /** Cria uma <ul> com itens de texto seguro a partir de um array. */
    function safeList(items) {
      const ul = document.createElement("ul");
      (items || []).forEach((item) => ul.appendChild(el("li", item)));
      return ul;
    }

    /** Cria uma <section> com título h3 e conteúdo DOM. */
    function section(title, bodyNode) {
      const sec = document.createElement("section");
      sec.appendChild(el("h3", title, "entry-section-title"));
      sec.appendChild(bodyNode);
      return sec;
    }

    function renderError(msg) {
      content.innerHTML = "";
      content.appendChild(el("p", msg, "muted"));
      const back = el("p");
      const a = el("a", "Voltar à busca");
      a.href = `${baseWithSlash}search`;
      back.appendChild(a);
      content.appendChild(back);
    }

    async function fetchJSON(url) {
      const res = await fetch(url);
      if (!res.ok) throw new Error(`Erro ${res.status} em ${url}`);
      return res.json();
    }

    function renderEntry(entry, volId, positionLabel) {
      const lemmas = (entry.lemmas || []).join(", ");
      const morph = entry.morph_render || entry.morfologia || "";
      const lang = entry.gloss_lang || "";

      // Atualiza o título da aba com o lema do verbete
      document.title = lemmas ? `${lemmas} | Dicionários` : "Verbete | Dicionários";

      content.innerHTML = "";

      // — Cabeçalho —
      const header = document.createElement("header");
      header.className = "entry-header";

      const headerLeft = document.createElement("div");
      const metaLine = el("p", `${volId}${positionLabel ? ` · ${positionLabel}` : ""}`, "muted entry-meta-line");
      const h1 = el("h1", lemmas, "entry-title");

      const pillList = document.createElement("div");
      pillList.className = "pill-list";
      pillList.setAttribute("aria-label", "Metadados do verbete");
      if (morph) pillList.appendChild(el("span", morph, "pill"));
      if (lang)  pillList.appendChild(el("span", lang, "pill"));
      if (entry.conf) pillList.appendChild(el("span", entry.conf, "pill"));
      if (entry.needs_review) pillList.appendChild(el("span", "revisar", "pill pill--warn"));
      if (entry.redirect_only) pillList.appendChild(el("span", "↪ remissiva", "pill"));

      headerLeft.appendChild(metaLine);
      headerLeft.appendChild(h1);
      headerLeft.appendChild(pillList);

      const headerActions = document.createElement("div");
      headerActions.className = "entry-actions";
      const copyBtn = el("button", "Copiar link", "button secondary");
      copyBtn.id = "btn-copy";
      const backLink = el("a", "Voltar", "button ghost");
      backLink.href = `${baseWithSlash}search`;
      headerActions.appendChild(copyBtn);
      headerActions.appendChild(backLink);

      header.appendChild(headerLeft);
      header.appendChild(headerActions);
      content.appendChild(header);

      // — Corpo do verbete —
      const article = document.createElement("article");
      article.className = "entry-body";

      const defP = el("p", entry.definicao || "Sem definição.");
      article.appendChild(section("Definição", defP));

      if (entry.translations?.length) {
        article.appendChild(section("Traduções", safeList(entry.translations)));
      }
      if (entry.morph_extra?.length) {
        article.appendChild(section("Morph extra", safeList(entry.morph_extra)));
      }
      if (entry.exemplos?.length) {
        article.appendChild(section("Exemplos", safeList(entry.exemplos)));
      }
      if (entry.notas) {
        article.appendChild(section("Notas", el("p", entry.notas)));
      }
      content.appendChild(article);

      // — Botão raw —
      const toggleBtn = el("button", "Ver raw", "button secondary");
      toggleBtn.id = "toggle-raw";
      toggleBtn.setAttribute("aria-expanded", "false");
      const rawPre = document.createElement("pre");
      rawPre.id = "raw";
      rawPre.className = "raw-pre";
      rawPre.style.display = "none";
      rawPre.textContent = entry.raw_text || "";
      content.appendChild(toggleBtn);
      content.appendChild(rawPre);

      toggleBtn.addEventListener("click", () => {
        const showing = rawPre.style.display !== "none";
        rawPre.style.display = showing ? "none" : "block";
        toggleBtn.textContent = showing ? "Ver raw" : "Ocultar raw";
        toggleBtn.setAttribute("aria-expanded", String(!showing));
      });

      copyBtn.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(window.location.href);
          copyBtn.textContent = "Copiado!";
          setTimeout(() => (copyBtn.textContent = "Copiar link"), 1500);
        } catch {
          copyBtn.textContent = "Erro ao copiar";
          setTimeout(() => (copyBtn.textContent = "Copiar link"), 1500);
        }
      });
    }

    async function load() {
      if (!idParam) {
        renderError("ID ausente na URL.");
        return;
      }
      const volumes = await fetchJSON(`${dataBaseUrl}/volumes.json`);
      const vol = volParam || volumes[0]?.id;
      if (!vol) {
        renderError("Nenhum volume disponível.");
        return;
      }
      const volMeta = await fetchJSON(`${baseWithSlash}data/${vol}/meta/${vol}.json`);
      const lookup = await fetchJSON(`${baseWithSlash}data/${vol}/lookup/${vol}-id-to-block.json`);
      const pos = lookup[idParam];
      if (!pos) {
        renderError("Verbete não encontrado neste volume.");
        return;
      }
      const blockFile = pos.block_file;
      const idxInBlock = Number(pos.idx_in_block ?? 0);
      const entries = await fetchJSON(`${baseWithSlash}data/${vol}/${blockFile}`);
      const entry = entries[idxInBlock]?.id === idParam ? entries[idxInBlock] : entries.find((e) => e.id === idParam);
      if (!entry) {
        renderError("Verbete não localizado no bloco.");
        return;
      }
      const blockIdx = volMeta.blocks.findIndex((b) => b.file === blockFile);
      const positionLabel =
        blockIdx >= 0 ? `bloco ${blockIdx + 1} · item ${idxInBlock + 1}` : `item ${idxInBlock + 1}`;
      renderEntry(entry, vol, positionLabel);
    }

    load().catch((err) => {
      console.error(err);
      // err.message seguro: usa textContent via renderError
      renderError(err.message);
    });
  </script>
</Layout>
