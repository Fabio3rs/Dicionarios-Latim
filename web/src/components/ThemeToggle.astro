<div class="theme-toggle" aria-label="Alternar tema">
  <button type="button" data-theme="light">Claro</button>
  <button type="button" data-theme="dark">Escuro</button>
  <button type="button" data-theme="auto">Auto</button>
</div>

<script>
  const buttons = Array.from(document.querySelectorAll(".theme-toggle button")) as HTMLButtonElement[];
  const valid = ["light", "dark", "auto"] as const;
  type Theme = typeof valid[number];

  function getChoice(): Theme {
    const s = localStorage.getItem("theme");
    return (valid as readonly string[]).includes(s ?? "") ? (s as Theme) : "auto";
  }

  function applyTheme(choice: Theme) {
    localStorage.setItem("theme", choice);
    // Armazena a escolha para que outros scripts possam ler
    document.documentElement.dataset.themeChoice = choice;

    // Calcula o tema visual efectivo
    const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
    const effective: Theme =
      choice === "auto" ? (prefersDark ? "dark" : "light") : choice;
    document.documentElement.setAttribute("data-theme", effective);

    // Marca o botão correspondente à *escolha*, não ao tema efectivo
    buttons.forEach((btn) =>
      btn.classList.toggle("active", btn.dataset.theme === choice)
    );
  }

  // Lê a escolha guardada (o script inline no <head> já aplicou o tema visual,
  // aqui só actualizamos os botões)
  applyTheme(getChoice());

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => applyTheme(btn.dataset.theme as Theme));
  });

  // Reage a mudanças do sistema operativo quando em modo "auto"
  window
    .matchMedia("(prefers-color-scheme: dark)")
    .addEventListener("change", () => {
      if (getChoice() === "auto") applyTheme("auto");
    });
</script>
